│   ├── MedicamentProduitSimultanementCA.java
│   ├── EffetIndesirableCA.java
│   ├── PriseChargeMedicaleCA.java
│   └── ComplementSuspecte.java
│
├── repository/                 # Repositories Spring Data JPA
│   ├── ComplementAlimentaireRepository.java
