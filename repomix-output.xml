            {/* Section 5 : Informations complémentaires + Commentaire AMMPS */}
            <section>
              <div className="flex items-center mb-4">
                <FileText className="w-6 h-6 text-slate-600 mr-2" />
                <h2 className="text-2xl font-bold text-slate-900">Informations complémentaires et Commentaire AMMPS</h2>
